# העתק קובץ זה ל-.env.local ומלא את הערכים.
# חשוב: .env.local לא נשמר ב-git (ראה .gitignore).

# מפתח ה-API של Anthropic — נדרש כדי לייצר ערכים.
# השג מפתח ב: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# מסד הנתונים (SQLite מקומי). ברירת מחדל טובה ל-v1.
DATABASE_URL="file:./dev.db"

# rate limit פר-IP על יצירת ערכים (0 = כבוי). ברירת מחדל: 3 לשעה.
RATE_LIMIT_CREATES_PER_HOUR=3

# Upstash Redis — ל-rate limit מבוזר בפרודקשן. בלעדיהם: מימוש in-memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# token לממשק הניהול /admin (חובה בפרודקשן; בלעדיו אין גישת admin בכלל).
ADMIN_TOKEN=

# rate limit לדיווחים (0 = כבוי). ברירת מחדל: 10 לשעה.
RATE_LIMIT_REPORTS_PER_HOUR=10

# שער-נושא (Haiku) לפני יצירה — סירוב קטגורי לאנשים חיים. מדליקים רק עם מפתח.
ENABLE_TOPIC_GATE=0
# קנוניזציה סמנטית של נושאים דרך השער (PLAN 1.5ב). מדליקים רק עם מפתח + eval.
ENABLE_SEMANTIC_NORMALIZE=0
