// perspectipedia — מודל נתונים
// Postgres (Neon בפרודקשן, מקומי/branch בפיתוח) — PLAN 2.1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Entry {
  id            String   @id @default(cuid())
  slug          String   @unique // נגזר מהנושא — מפתח לחיפוש וקישור
  topic         String            // הנושא כפי שהוקלד ("בריאת העולם")
  topicKind     String            // meaning / mixed / empirical
  status        String   @default("published") // pending / published / needs_review / refused / failed / removed
  refusalReason String?           // אם status=refused — הסיבה (לשנאה/אדם פרטי/נזק)
  lastError     String?           // אם status=failed — השגיאה האחרונה
  crux          String?           // "מוקד המחלוקת" — נכתב מחוקה v3 (PLAN 4.3)
  canonicalTopic String?          // כותרת קנונית מהנרמול הסמנטי (PLAN 1.5ב, M4)
  depth         String   @default("standard") // summary / standard / deep — בחירת הקורא (D7); נאכף ביצירה מ-v3

  // job-row (PLAN 5.1): שורת pending היא המנעול והתור — unique slug = mutex.
  generationStartedAt DateTime?   // לשחרור pending תקוע (timeout)
  attemptCount        Int      @default(0)
  lenses        Lens[]
  reports       Report[]
  aliases       TopicAlias[]

  // provenance — זול עכשיו, קריטי אחר כך (עריכה היברידית, מעקב איכות)
  promptVersion String   @default("v1")
  model         String   @default("claude-opus-4-8")
  inputTokens   Int?              // usage — לניהול עלויות
  outputTokens  Int?
  costUsd       Float?            // עלות מוערכת לפי מחירון (docs/COST_AND_KEY.md)
  rawOutput     String?           // פלט המודל הגולמי — post-mortem בלי לשחזר יצירה
  auditVerdict  String?           // pass / revise / fail — תוצאת המבקר (PLAN 3.7)
  auditJson     Json?             // AuditResult מלא — דשבורד הטיה עתידי

  createdAt     DateTime @default(now())

  @@index([createdAt])
}

// פרופיל עדשה — "ספריית העולמות" (D10, PLAN 4.11): תפקיד מוגדר + הגות אצורה + קול קבוע
// לכל עולם-תוכן. היצירה (מ-v3.5) מפעילה פרופיל, לא ממציאה עדשה. חתימת אינסיינדר
// ברמת הפרופיל — אישור אחד משפר את כל הערכים העתידיים.
model LensProfile {
  id             String   @id @default(cuid())
  key            String   @unique          // "haredi-litai", "scientific-mainstream"...
  locale         String   @default("he")
  name           String                     // שם תצוגה: "יהדות חרדית-ליטאית"
  family         String                     // religious/scientific/philosophical/political/cultural/historical
  role           String                     // הדמות: מי כותב, לאיזה קהל, מאיזו עמדה
  canon          Json                       // [{source, why, weight}] — כפי שהעולם עצמו מדרג
  register       String                     // איך העולם נשמע: ביטויים, סגנון, מה נחשב טיעון טוב
  internalDebates Json                      // [string] — מחלוקות פנימיות שאסור לשטח
  voice          String   @default("first-person") // first-person / faithful-description (D1.4)
  redFlags       Json                       // [string] — מה מסגיר זיוף ("נשמע כמו תרגום מאנגלית כש...")
  status         String   @default("draft") // draft / insider_approved / deprecated
  version        Int      @default(1)
  approvedBy     String?                    // תיאור האינסיינדר המאשר (לא PII מלא)
  approvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ניסוח חלופי של נושא שמנתב לערך קיים (PLAN 1.5) — מונע כפילויות ("שואה"/"השואה").
model TopicAlias {
  id        String   @id @default(cuid())
  alias     String   @unique          // slug מנורמל של הניסוח החלופי
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  source    String                    // deterministic / semantic / admin
  createdAt DateTime @default(now())
}

// דיווח קורא על בעיה/הטיה בערך (PLAN 1.4) — מוצג ב-admin, מזין את ה-eval בהמשך.
model Report {
  id        String   @id @default(cuid())
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lensName  String?           // אופציונלי: על איזו עדשה הדיווח
  reason    String
  status    String   @default("open") // open / resolved
  createdAt DateTime @default(now())

  @@index([status, createdAt])
}

model Lens {
  id            String  @id @default(cuid())
  entryId       String
  entry         Entry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  name          String            // "יהדות דתית"
  family        String            // religious / scientific / philosophical / political / cultural / historical
  summary       String            // תמצית 1-2 משפטים
  body          String            // גוף הערך מהעדשה הזו
  grounding     Json              // [{ source, explanation, url? }] — "על מה זה מבוסס"
  epistemicType String            // meaning-narrative / value-position / empirical-grounded / methodological-critique
  confidence    String?           // סייג אופציונלי
  order         Int               // סדר תצוגה
  editedByHuman Boolean @default(false) // תשתית לצעד ההיברידי (v2)

  // קישור לפרופיל שהזריק את העדשה (D10 pilot) — כך שאישור/עדכון פרופיל
  // יודע לאתר אילו עדשות קיימות נוצרו ממנו ולסמן אותן ל-regenerate.
  profileKey     String?
  profileVersion Int?

  @@index([entryId])
  @@index([profileKey])
}
